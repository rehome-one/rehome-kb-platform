# reHome KB — environment variables reference (local-dev)
#
# ADR-0009: реальные секреты живут encrypted в `deploy/secrets/*.enc.yaml`.
# Этот файл — TEMPLATE / справочник, какие keys нужны compose'у. Real
# values приходят через `make -C infra decrypt-dev` → `.env.local` в repo root.
#
# Production значения — через k8s Secret / orchestrator's secret API
# (см. ADR-0009 §"Решение"). Никаких prod credentials в репо.
#
# Discipline: secrets (помечены `# SECRET`) compose'ом required'ятся через
# `${VAR:?...}` — pipeline fail'ит fast если не выставлены. Никакого
# silent fallback'а на embedded dev passwords.

# ============================================================================
# Keycloak admin console (http://localhost:8080)
# ============================================================================
KEYCLOAK_ADMIN=admin
# SECRET — required.
KEYCLOAK_ADMIN_PASSWORD=

# ============================================================================
# Keycloak Postgres backend
# ============================================================================
POSTGRES_KEYCLOAK_DB=keycloak
POSTGRES_KEYCLOAK_USER=keycloak
# SECRET — required.
POSTGRES_KEYCLOAK_PASSWORD=

# ============================================================================
# Keycloak m2m client (rehome-platform-m2m)
# ============================================================================
# SECRET — этот же secret сохранён в infra/keycloak/realm-export.json для
# импорта realm; смены требуют пере-импорта realm или ручного обновления
# через Admin Console.
KEYCLOAK_M2M_CLIENT_SECRET=

# ============================================================================
# Postgres для kb-API (articles/documents/...). Отдельный инстанс от
# Keycloak-Postgres. Backend читает через DATABASE_URL.
# ============================================================================
POSTGRES_KB_DB=rehome_kb
POSTGRES_KB_USER=kb
# SECRET — required.
POSTGRES_KB_PASSWORD=
